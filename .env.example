# ============================================
# Email Analysis Tool — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Database ---
POSTGRES_USER=emailanalysis
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=email_analysis
DATABASE_URL=postgresql+asyncpg://emailanalysis:changeme_secure_password@db:5432/email_analysis

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=generate-a-random-secret-key-here
MAX_UPLOAD_SIZE_MB=25
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- External API Keys (all optional) ---
VIRUSTOTAL_API_KEY=
URLSCAN_API_KEY=
ABUSEIPDB_API_KEY=
ALIENVAULT_OTX_API_KEY=
GOOGLE_SAFEBROWSING_API_KEY=

# --- Risk Scoring Weights ---
WEIGHT_HEADER_ANOMALY=25
WEIGHT_AUTH_FAILURE=20
WEIGHT_SENDER_SPOOF=15
WEIGHT_SUSPICIOUS_ATTACHMENT=30
WEIGHT_MALICIOUS_URL=40
WEIGHT_PHISHING_KEYWORDS=15
WEIGHT_BRAND_IMPERSONATION=20
WEIGHT_BEC_INDICATORS=25

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
